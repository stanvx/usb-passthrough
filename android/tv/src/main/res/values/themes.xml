<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    Splash / window theme for the TV app.
    The Compose TvTheme handles the real Material3 theming;
    this XML theme is only shown briefly before Compose takes over.
    -->
    <style name="Theme.Leanback" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
