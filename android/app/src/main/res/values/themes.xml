<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
    Splash / window theme for the phone app.
    The Compose AnyPlugTheme handles the real Material3 theming;
    this XML theme is only shown briefly at app start before
    Compose takes over.
    -->
    <style name="Theme.AnyPlug" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
