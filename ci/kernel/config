# Minimal kernel config fragment for USB/IP CI smoke tests
# All USB gadget and dummy HCD options compiled in (=y, not =m)
# so no modprobe is needed at runtime.

# Dummy HCD — emulates a USB host controller in software
CONFIG_USB_DUMMY_HCD=y

# USB Gadget support — core framework
CONFIG_USB_GADGET=y
CONFIG_USB_LIBCOMPOSITE=y

# ConfigFS-based gadget creation
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_F_HID=y
CONFIG_USB_CONFIGFS_F_ACM=y
CONFIG_USB_CONFIGFS_F_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_F_SERIAL=y

# USB function drivers (built-in, not modules)
CONFIG_USB_U_SERIAL=y
CONFIG_USB_F_ACM=y
CONFIG_USB_F_MASS_STORAGE=y
CONFIG_USB_F_HID=y

# Minimal serial/tty support for initramfs console
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=4
CONFIG_SERIAL_EARLYCON=y

# Minimal block/virtio for rootfs and 9p sharing
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_9P=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_9P_FS_POSIX_ACL=y

# Required kernel features for boot
CONFIG_EMBEDDED=y
CONFIG_EXPERT=y

# PCI support (QEMU default)
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y

# Proc/sysfs/devtmpfs
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# Power-off support
CONFIG_PM=y
CONFIG_PM_SLEEP=y

# HID support (needed for gadget HID function)
CONFIG_HID=y
CONFIG_USB_HID=y

# Block layer for storage gadget tests
CONFIG_BLOCK=y

# tmpfs for initramfs
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y

# Misc
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
CONFIG_EARLY_PRINTK_DBGP=y
