{
  "openapi": "3.1.0",
  "info": {
    "title": "AnyPlug USB/IP Server API",
    "description": "REST API + WebSocket events for managing a USB/IP server.\n\nAll error responses follow the structured format with:\n- `correlation_id` (UUIDv7) — trace the error through logs\n- `category` — `transient`, `permanent`, or `fatal`\n- `message` — human-readable description\n\nFor port documentation see [PORTS.md](./PORTS.md).",
    "version": "0.1.0"
  },
  "servers": [
    {
      "url": "http://{host}:{port}",
      "variables": {
        "host": { "default": "localhost" },
        "port": { "default": "3241" }
      }
    }
  ],
  "paths": {
    "/api/status": {
      "get": {
        "summary": "Server status and metrics",
        "description": "Returns server uptime, active connections, URB throughput, and error count.",
        "operationId": "getStatus",
        "responses": {
          "200": {
            "description": "Server status",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/StatusResponse" }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/devices": {
      "get": {
        "summary": "List exported devices",
        "description": "Returns all exportable USB devices with VID, PID, status, and connected client.",
        "operationId": "getDevices",
        "responses": {
          "200": {
            "description": "Device list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DeviceResponse" }
                }
              }
            }
          }
        }
      }
    },
    "/api/config": {
      "get": {
        "summary": "Read server configuration",
        "description": "Returns current server configuration with secrets redacted.",
        "operationId": "getConfig",
        "responses": {
          "200": {
            "description": "Server configuration",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiConfig" }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Update server configuration",
        "description": "Partially update server configuration. Only the fields included in the request body are changed. Port values are validated and return a structured 400 error if out of range.",
        "operationId": "putConfig",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConfigUpdateRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated configuration",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiConfig" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/connect": {
      "post": {
        "summary": "Connect to remote device",
        "description": "Import a device from a remote USB/IP server. Returns the imported device's bus ID and identifiers.",
        "operationId": "postConnect",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ConnectRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Device imported successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ConnectResponse" }
              }
            }
          },
          "500": {
            "description": "Import failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/disconnect": {
      "post": {
        "summary": "Disconnect a device",
        "description": "Release an imported device by busid.",
        "operationId": "postDisconnect",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DisconnectRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Disconnected successfully"
          },
          "404": {
            "description": "Device not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Disconnect failed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/api/scan": {
      "post": {
        "summary": "Discover USB/IP servers on LAN",
        "description": "Browse the local network for USB/IP servers via mDNS (`_usbip._tcp.local`). Returns discovered servers and their device listings.",
        "operationId": "postScan",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ScanRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "List of discovered servers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/DiscoveredServer" }
                }
              }
            }
          }
        }
      }
    },
    "/api/events": {
      "get": {
        "summary": "WebSocket event stream",
        "description": "Upgrade to WebSocket. Streams real-time events as JSON text frames:\n\n- `connected` — WebSocket handshake complete\n- `latency` — per-URB round-trip latency sample\n  ```json\n  {\"type\":\"latency\",\"payload\":{\"time\":\"12:34:56\",\"latency_us\":450,\"device\":\"1-1\"}}\n  ```\n- `error` — a server error occurred\n\nEach frame is a JSON object with `type` (string) and `payload` (object) fields.",
        "operationId": "wsEvents"
      }
    },
    "/api/openapi.json": {
      "get": {
        "summary": "OpenAPI specification",
        "description": "Returns this OpenAPI specification as JSON.",
        "operationId": "getOpenApi",
        "responses": {
          "200": {
            "description": "OpenAPI specification",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "StatusResponse": {
        "type": "object",
        "required": ["status", "uptime_seconds", "active_connections", "urb_throughput", "error_count"],
        "properties": {
          "status": {
            "type": "string",
            "description": "Server status",
            "example": "running"
          },
          "uptime_seconds": {
            "type": "number",
            "description": "Server uptime in seconds",
            "example": 1234.56
          },
          "active_connections": {
            "type": "integer",
            "description": "Number of active client connections",
            "example": 2
          },
          "urb_throughput": {
            "type": "integer",
            "description": "URB throughput counter",
            "example": 15000
          },
          "error_count": {
            "type": "integer",
            "description": "Total error count",
            "example": 0
          }
        }
      },
      "DeviceResponse": {
        "type": "object",
        "required": ["busid", "vid", "pid", "speed", "status", "path"],
        "properties": {
          "busid": {
            "type": "string",
            "description": "USB bus ID",
            "example": "1-1"
          },
          "vid": {
            "type": "integer",
            "description": "USB vendor ID",
            "example": 1133
          },
          "pid": {
            "type": "integer",
            "description": "USB product ID",
            "example": 49761
          },
          "speed": {
            "type": "integer",
            "description": "USB speed code",
            "example": 3
          },
          "status": {
            "type": "string",
            "description": "Device status: available or exported",
            "example": "available"
          },
          "connected_client": {
            "type": "string",
            "description": "Connected client address, if exported",
            "nullable": true,
            "example": "192.168.1.5:45231"
          },
          "path": {
            "type": "string",
            "description": "Sysfs device path",
            "example": "/sys/bus/usb/devices/1-1"
          }
        }
      },
      "ApiConfig": {
        "type": "object",
        "required": ["bind_address", "port", "api_port", "encryption_enabled"],
        "properties": {
          "bind_address": {
            "type": "string",
            "description": "Server bind address for all ports",
            "example": "0.0.0.0"
          },
          "port": {
            "type": "integer",
            "description": "Wire port: USB/IP TCP port for core protocol traffic",
            "minimum": 1,
            "maximum": 65535,
            "example": 3240
          },
          "api_port": {
            "type": "integer",
            "description": "API port: REST API and WebSocket port",
            "minimum": 1,
            "maximum": 65535,
            "example": 3241
          },
          "encryption_enabled": {
            "type": "boolean",
            "description": "Whether AES-256-GCM encryption is enabled for USB/IP traffic",
            "example": false
          }
        }
      },
      "ConfigUpdateRequest": {
        "type": "object",
        "description": "Partial update to server configuration. Only included fields are changed.",
        "properties": {
          "bind_address": {
            "type": "string",
            "description": "Server bind address"
          },
          "port": {
            "type": "integer",
            "description": "Wire port: USB/IP TCP port",
            "minimum": 1,
            "maximum": 65535,
            "example": 3240
          },
          "api_port": {
            "type": "integer",
            "description": "API port: REST API and WebSocket port",
            "minimum": 1,
            "maximum": 65535,
            "example": 3241
          },
          "encryption_enabled": {
            "type": "boolean",
            "description": "Whether AES-256-GCM encryption is enabled"
          }
        }
      },
      "ConnectRequest": {
        "type": "object",
        "required": ["host", "port", "busid"],
        "properties": {
          "host": {
            "type": "string",
            "description": "Remote server hostname or IP",
            "example": "192.168.1.100"
          },
          "port": {
            "type": "integer",
            "description": "Remote server wire port",
            "minimum": 1,
            "maximum": 65535,
            "example": 3240
          },
          "busid": {
            "type": "string",
            "description": "Device bus ID to connect to",
            "example": "1-1"
          }
        }
      },
      "ConnectResponse": {
        "type": "object",
        "required": ["busid", "vid", "pid", "status"],
        "properties": {
          "busid": {
            "type": "string",
            "description": "Imported device bus ID",
            "example": "1-1"
          },
          "vid": {
            "type": "integer",
            "description": "USB vendor ID",
            "example": 1133
          },
          "pid": {
            "type": "integer",
            "description": "USB product ID",
            "example": 49761
          },
          "status": {
            "type": "string",
            "description": "Import status, always \"imported\" on success",
            "example": "imported"
          }
        }
      },
      "DisconnectRequest": {
        "type": "object",
        "required": ["busid"],
        "properties": {
          "busid": {
            "type": "string",
            "description": "Device bus ID to disconnect",
            "example": "1-1"
          }
        }
      },
      "ScanRequest": {
        "type": "object",
        "description": "Scan parameters. All fields are optional.",
        "properties": {
          "timeout_secs": {
            "type": "integer",
            "description": "mDNS browse timeout in seconds (clamped to 1-30, default 5)",
            "minimum": 1,
            "maximum": 30,
            "default": 5,
            "example": 5
          }
        }
      },
      "DiscoveredServer": {
        "type": "object",
        "required": ["host", "port", "txt"],
        "properties": {
          "host": {
            "type": "string",
            "description": "Server hostname or IP",
            "example": "192.168.1.100"
          },
          "port": {
            "type": "integer",
            "description": "Wire port of the remote server",
            "example": 3240
          },
          "txt": {
            "type": "object",
            "description": "mDNS TXT record key-value pairs",
            "additionalProperties": { "type": "string" },
            "example": { "version": "0.1.0", "devices": "2" }
          }
        }
      },
      "ApiErrorResponse": {
        "type": "object",
        "required": ["correlation_id", "category", "message"],
        "properties": {
          "correlation_id": {
            "type": "string",
            "description": "UUIDv7 correlation ID for tracing",
            "example": "0196a8b3-e72e-71b6-9f3e-ba3b9d4a6f89"
          },
          "category": {
            "type": "string",
            "description": "Error category: transient, permanent, or fatal",
            "example": "permanent"
          },
          "message": {
            "type": "string",
            "description": "Human-readable error message",
            "example": "Remote connection failed: timeout"
          }
        }
      }
    }
  }
}
