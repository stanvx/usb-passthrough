<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Entitlements for AnyPlug USB/IP Server on macOS.

        com.apple.security.device.usb is required for IOKit USB access
        on macOS 10.14+ with hardened runtime.

        com.apple.security.cs.disable-library-validation allows linking
        against libusb (not signed by Apple).

        Apply with:
            codesign -f -s - --entitlements usbip.entitlements \
                --option runtime target/release/usbip-server
    -->
    <key>com.apple.security.device.usb</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
</dict>
</plist>
